{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatsense.local/contracts/forecasting_report.schema.json",
  "title": "ChatSense Stage 5 Forecasting Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_version", "source", "dataset_identity", "fixture_count", "fixtures"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "contract_version": { "type": "string" },
    "source": { "enum": ["typescript", "python", "parity"] },
    "dataset_identity": { "type": "string" },
    "fixture_count": { "type": "integer", "minimum": 0 },
    "fixtures": { "type": "array", "items": { "$ref": "#/$defs/fixture" } }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "cases", "status", "summary", "opportunities", "tasks", "validation_evidence"],
      "properties": {
        "fixture": { "type": "string" },
        "cases": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "summary": { "$ref": "#/$defs/summary" },
        "opportunities": { "$ref": "#/$defs/opportunities" },
        "tasks": { "$ref": "#/$defs/tasks" },
        "validation_evidence": { "$ref": "#/$defs/validationEvidence" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_promotion",
        "reply_opportunity_count",
        "observed_reply_count",
        "completed_activity_window_count",
        "reasons"
      ],
      "properties": {
        "product_promotion": { "type": "boolean" },
        "reply_opportunity_count": { "type": "integer", "minimum": 0 },
        "observed_reply_count": { "type": "integer", "minimum": 0 },
        "completed_activity_window_count": { "type": "integer", "minimum": 0 },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "opportunities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reply"],
      "properties": {
        "reply": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "observed_responses", "final_open_turns", "group_approximation"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "observed_responses": { "type": "integer", "minimum": 0 },
            "final_open_turns": { "type": "integer", "minimum": 0 },
            "group_approximation": { "type": "boolean" }
          }
        }
      }
    },
    "tasks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reply_within_horizon", "conditional_reply_delay_bucket", "next_window_activity"],
      "properties": {
        "reply_within_horizon": {
          "type": "array",
          "items": { "$ref": "#/$defs/replyHorizonTask" }
        },
        "conditional_reply_delay_bucket": { "$ref": "#/$defs/delayTask" },
        "next_window_activity": { "$ref": "#/$defs/activityTask" }
      }
    },
    "replyHorizonTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "horizon_minutes",
        "eligible_count",
        "censored_count",
        "prediction_records",
        "metrics",
        "best_baseline_key",
        "candidate_relative_brier_improvement_pct",
        "candidate_improvement_over_best_baseline_pct",
        "bootstrap",
        "subgroup_checks",
        "promotion"
      ],
      "properties": {
        "horizon_minutes": { "type": "integer" },
        "eligible_count": { "type": "integer", "minimum": 0 },
        "censored_count": { "type": "integer", "minimum": 0 },
        "prediction_records": { "type": "array", "items": { "$ref": "#/$defs/binaryPredictionRecord" } },
        "metrics": { "$ref": "#/$defs/binaryEstimatorMetrics" },
        "best_baseline_key": { "type": ["string", "null"] },
        "candidate_relative_brier_improvement_pct": { "$ref": "#/$defs/binaryBaselineNumberMap" },
        "candidate_improvement_over_best_baseline_pct": { "type": ["number", "null"] },
        "bootstrap": { "$ref": "#/$defs/bootstrap" },
        "subgroup_checks": { "type": "array", "items": { "$ref": "#/$defs/subgroupCheck" } },
        "promotion": { "$ref": "#/$defs/promotion" }
      }
    },
    "delayTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_response_count",
        "evaluated_count",
        "class_support",
        "best_baseline_key",
        "insufficient_support",
        "prediction_records",
        "metrics",
        "promotion"
      ],
      "properties": {
        "observed_response_count": { "type": "integer", "minimum": 0 },
        "evaluated_count": { "type": "integer", "minimum": 0 },
        "class_support": { "$ref": "#/$defs/delayClassNumberMap" },
        "best_baseline_key": { "type": ["string", "null"] },
        "insufficient_support": { "type": "boolean" },
        "prediction_records": { "type": "array", "items": { "$ref": "#/$defs/delayPredictionRecord" } },
        "metrics": { "$ref": "#/$defs/delayEstimatorMetrics" },
        "promotion": { "$ref": "#/$defs/promotion" }
      }
    },
    "activityTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completed_window_count",
        "evaluated_count",
        "best_baseline_key",
        "candidate_improvement_over_best_baseline_pct",
        "prediction_records",
        "metrics",
        "promotion"
      ],
      "properties": {
        "completed_window_count": { "type": "integer", "minimum": 0 },
        "evaluated_count": { "type": "integer", "minimum": 0 },
        "best_baseline_key": { "type": ["string", "null"] },
        "candidate_improvement_over_best_baseline_pct": { "type": ["number", "null"] },
        "prediction_records": { "type": "array", "items": { "$ref": "#/$defs/activityPredictionRecord" } },
        "metrics": { "$ref": "#/$defs/activityEstimatorMetrics" },
        "promotion": { "$ref": "#/$defs/promotion" }
      }
    },
    "binaryEstimatorMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "participant", "recent", "time_context", "candidate"],
      "properties": {
        "global": { "$ref": "#/$defs/binaryMetric" },
        "participant": { "$ref": "#/$defs/binaryMetric" },
        "recent": { "$ref": "#/$defs/binaryMetric" },
        "time_context": { "$ref": "#/$defs/binaryMetric" },
        "candidate": { "$ref": "#/$defs/binaryMetric" }
      }
    },
    "binaryMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluated_count",
        "positive_count",
        "negative_count",
        "brier_score",
        "log_loss",
        "calibration_error",
        "calibration_bins",
        "non_empty_calibration_bins",
        "accuracy",
        "precision",
        "recall",
        "relative_brier_improvement_pct"
      ],
      "properties": {
        "evaluated_count": { "type": "integer", "minimum": 0 },
        "positive_count": { "type": "integer", "minimum": 0 },
        "negative_count": { "type": "integer", "minimum": 0 },
        "brier_score": { "type": ["number", "null"] },
        "log_loss": { "type": ["number", "null"] },
        "calibration_error": { "type": ["number", "null"] },
        "calibration_bins": { "type": "array", "items": { "$ref": "#/$defs/calibrationBin" } },
        "non_empty_calibration_bins": { "type": "integer", "minimum": 0 },
        "accuracy": { "type": ["number", "null"] },
        "precision": { "type": ["number", "null"] },
        "recall": { "type": ["number", "null"] },
        "relative_brier_improvement_pct": { "type": ["number", "null"] }
      }
    },
    "calibrationBin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lower_bound", "upper_bound", "mean_predicted", "observed_rate", "count"],
      "properties": {
        "lower_bound": { "type": "number" },
        "upper_bound": { "type": "number" },
        "mean_predicted": { "type": ["number", "null"] },
        "observed_rate": { "type": ["number", "null"] },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "delayEstimatorMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "participant", "recent", "time_context", "candidate"],
      "properties": {
        "global": { "$ref": "#/$defs/delayMetric" },
        "participant": { "$ref": "#/$defs/delayMetric" },
        "recent": { "$ref": "#/$defs/delayMetric" },
        "time_context": { "$ref": "#/$defs/delayMetric" },
        "candidate": { "$ref": "#/$defs/delayMetric" }
      }
    },
    "delayMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluated_count",
        "accuracy",
        "balanced_accuracy",
        "macro_f1",
        "log_loss",
        "confusion_matrix",
        "per_class",
        "class_support"
      ],
      "properties": {
        "evaluated_count": { "type": "integer", "minimum": 0 },
        "accuracy": { "type": ["number", "null"] },
        "balanced_accuracy": { "type": ["number", "null"] },
        "macro_f1": { "type": ["number", "null"] },
        "log_loss": { "type": ["number", "null"] },
        "confusion_matrix": { "$ref": "#/$defs/confusionMatrix" },
        "per_class": { "$ref": "#/$defs/delayPerClass" },
        "class_support": { "$ref": "#/$defs/delayClassNumberMap" }
      }
    },
    "activityEstimatorMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previous", "historical_mean", "rolling_mean", "ewma", "candidate"],
      "properties": {
        "previous": { "$ref": "#/$defs/regressionMetric" },
        "historical_mean": { "$ref": "#/$defs/regressionMetric" },
        "rolling_mean": { "$ref": "#/$defs/regressionMetric" },
        "ewma": { "$ref": "#/$defs/regressionMetric" },
        "candidate": { "$ref": "#/$defs/regressionMetric" }
      }
    },
    "regressionMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluated_count", "mae", "median_absolute_error", "rmse", "safe_mape"],
      "properties": {
        "evaluated_count": { "type": "integer", "minimum": 0 },
        "mae": { "type": ["number", "null"] },
        "median_absolute_error": { "type": ["number", "null"] },
        "rmse": { "type": ["number", "null"] },
        "safe_mape": { "type": ["number", "null"] }
      }
    },
    "binaryPredictionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opportunity_id", "participant_context", "prediction_time", "outcome", "probabilities"],
      "properties": {
        "opportunity_id": { "type": "string" },
        "participant_context": { "type": "string" },
        "prediction_time": { "type": "string" },
        "outcome": { "type": "boolean" },
        "probabilities": { "$ref": "#/$defs/binaryEstimatorNumberMap" }
      }
    },
    "delayPredictionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opportunity_id", "participant_context", "prediction_time", "bucket", "distributions"],
      "properties": {
        "opportunity_id": { "type": "string" },
        "participant_context": { "type": "string" },
        "prediction_time": { "type": "string" },
        "bucket": { "$ref": "#/$defs/delayBucket" },
        "distributions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["global", "participant", "recent", "time_context", "candidate"],
          "properties": {
            "global": { "$ref": "#/$defs/delayClassNumberMap" },
            "participant": { "$ref": "#/$defs/delayClassNumberMap" },
            "recent": { "$ref": "#/$defs/delayClassNumberMap" },
            "time_context": { "$ref": "#/$defs/delayClassNumberMap" },
            "candidate": { "$ref": "#/$defs/delayClassNumberMap" }
          }
        }
      }
    },
    "activityPredictionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_index",
        "prediction_time",
        "target_window_start",
        "target_window_end",
        "actual",
        "predictions",
        "absolute_errors"
      ],
      "properties": {
        "window_index": { "type": "integer" },
        "prediction_time": { "type": "string" },
        "target_window_start": { "type": "string" },
        "target_window_end": { "type": "string" },
        "actual": { "type": "number" },
        "predictions": { "$ref": "#/$defs/activityEstimatorNumberMap" },
        "absolute_errors": { "$ref": "#/$defs/activityEstimatorNumberMap" }
      }
    },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "resample_count",
        "confidence_level",
        "point_estimate",
        "lower_bound",
        "upper_bound",
        "strongly_inferior",
        "unavailable_reason"
      ],
      "properties": {
        "seed": { "type": "integer" },
        "resample_count": { "type": "integer" },
        "confidence_level": { "type": "number" },
        "point_estimate": { "type": ["number", "null"] },
        "lower_bound": { "type": ["number", "null"] },
        "upper_bound": { "type": ["number", "null"] },
        "strongly_inferior": { "type": "boolean" },
        "unavailable_reason": { "type": ["string", "null"] }
      }
    },
    "subgroupCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subgroup",
        "sample_count",
        "candidate_score",
        "best_baseline_score",
        "degradation",
        "eligible",
        "catastrophic_failure"
      ],
      "properties": {
        "subgroup": { "type": "string" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "candidate_score": { "type": ["number", "null"] },
        "best_baseline_score": { "type": ["number", "null"] },
        "degradation": { "type": ["number", "null"] },
        "eligible": { "type": "boolean" },
        "catastrophic_failure": { "type": "boolean" }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promoted", "state", "method_gate_passed", "reasons"],
      "properties": {
        "promoted": { "type": "boolean" },
        "state": { "type": "string" },
        "method_gate_passed": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_kind",
        "conversation_count",
        "independent_conversation_count",
        "evaluated_opportunity_count",
        "provenance",
        "bootstrap_completed",
        "subgroup_checks_completed",
        "real_world_validation_eligible"
      ],
      "properties": {
        "dataset_kind": { "type": "string" },
        "conversation_count": { "type": "integer", "minimum": 0 },
        "independent_conversation_count": { "type": "integer", "minimum": 0 },
        "evaluated_opportunity_count": { "type": "integer", "minimum": 0 },
        "provenance": { "type": "string" },
        "bootstrap_completed": { "type": "boolean" },
        "subgroup_checks_completed": { "type": "boolean" },
        "real_world_validation_eligible": { "type": "boolean" }
      }
    },
    "delayBucket": { "enum": ["under_1h", "1h_6h", "6h_24h", "over_24h"] },
    "binaryEstimatorNumberMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "participant", "recent", "time_context", "candidate"],
      "properties": {
        "global": { "type": "number" },
        "participant": { "type": "number" },
        "recent": { "type": "number" },
        "time_context": { "type": "number" },
        "candidate": { "type": "number" }
      }
    },
    "binaryBaselineNumberMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "participant", "recent", "time_context"],
      "properties": {
        "global": { "type": ["number", "null"] },
        "participant": { "type": ["number", "null"] },
        "recent": { "type": ["number", "null"] },
        "time_context": { "type": ["number", "null"] }
      }
    },
    "delayClassNumberMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["under_1h", "1h_6h", "6h_24h", "over_24h"],
      "properties": {
        "under_1h": { "type": "number" },
        "1h_6h": { "type": "number" },
        "6h_24h": { "type": "number" },
        "over_24h": { "type": "number" }
      }
    },
    "activityEstimatorNumberMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previous", "historical_mean", "rolling_mean", "ewma", "candidate"],
      "properties": {
        "previous": { "type": "number" },
        "historical_mean": { "type": "number" },
        "rolling_mean": { "type": "number" },
        "ewma": { "type": "number" },
        "candidate": { "type": "number" }
      }
    },
    "confusionMatrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["under_1h", "1h_6h", "6h_24h", "over_24h"],
      "properties": {
        "under_1h": { "$ref": "#/$defs/delayClassNumberMap" },
        "1h_6h": { "$ref": "#/$defs/delayClassNumberMap" },
        "6h_24h": { "$ref": "#/$defs/delayClassNumberMap" },
        "over_24h": { "$ref": "#/$defs/delayClassNumberMap" }
      }
    },
    "delayPerClass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["under_1h", "1h_6h", "6h_24h", "over_24h"],
      "properties": {
        "under_1h": { "$ref": "#/$defs/classMetric" },
        "1h_6h": { "$ref": "#/$defs/classMetric" },
        "6h_24h": { "$ref": "#/$defs/classMetric" },
        "over_24h": { "$ref": "#/$defs/classMetric" }
      }
    },
    "classMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support", "precision", "recall", "f1"],
      "properties": {
        "support": { "type": "integer", "minimum": 0 },
        "precision": { "type": ["number", "null"] },
        "recall": { "type": ["number", "null"] },
        "f1": { "type": ["number", "null"] }
      }
    }
  }
}
